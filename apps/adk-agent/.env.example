# MCP server API keys (same as miroflow-agent)
SERPER_API_KEY=
JINA_API_KEY=
E2B_API_KEY=
SUMMARY_LLM_BASE_URL=
SUMMARY_LLM_MODEL_NAME=
SUMMARY_LLM_API_KEY=

# Model configuration (choose one)
GOOGLE_API_KEY=           # For Gemini via ADK native
# OR for LiteLLM:
OPENAI_API_BASE=          # vLLM endpoint for Qwen/MiroThinker models
OPENAI_API_KEY=

# ADK agent model (used by agents/*.py)
# Examples:
#   ADK_MODEL=gemini-2.0-flash
#   ADK_MODEL=litellm/openai/gpt-4o
ADK_MODEL=litellm/openai/gpt-4o

# Algorithm tuning
KEEP_TOOL_RESULT=5          # Algorithm 5: number of recent tool results to keep
MAX_CONTEXT_TOKENS=128000   # Algorithm 5: force final answer above this threshold
CONTEXT_COMPRESS_LIMIT=5    # Algorithm 6: max retry attempts

# Phoenix self-hosted observability (https://phoenix.arize.com)
# Start local server: python -m phoenix.server.main serve
# Dashboard: http://localhost:6006
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces

# Optional
DEMO_MODE=                  # Set to "1" to truncate scrape results to 20K chars
