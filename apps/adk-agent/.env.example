# MCP server API keys (same as miroflow-agent)
SERPER_API_KEY=
JINA_API_KEY=
E2B_API_KEY=
SUMMARY_LLM_BASE_URL=
SUMMARY_LLM_MODEL_NAME=
SUMMARY_LLM_API_KEY=

# Official MCP server API keys
BRAVE_API_KEY=              # Brave Search MCP server
FIRECRAWL_API_KEY=          # Firecrawl MCP server
EXA_API_KEY=                # Exa search MCP server (get key at https://exa.ai)
KAGI_API_KEY=               # Kagi MCP server (search, summarize, fastgpt, enrich)
TRANSCRIPTAPI_KEY=          # TranscriptAPI MCP (YouTube transcripts, search, channels, playlists)

# Model configuration (choose one)
GOOGLE_API_KEY=           # For Gemini via ADK native
# OR for LiteLLM:
OPENAI_API_BASE=          # vLLM endpoint for Qwen/MiroThinker models
OPENAI_API_KEY=

# ADK agent model (used by agents/*.py via agents/model_config.py)
# Do NOT add :param=value suffixes — vendor-specific params go in VENICE_PARAMS.
# Examples:
#   ADK_MODEL=gemini-2.0-flash
#   ADK_MODEL=litellm/openai/gpt-4o
#   ADK_MODEL=openai/zai-org-glm-4.7  (Venice GLM-4.7)
#   ADK_MODEL=openai/qwen3-30b-a3b-abliterated  (RunPod vLLM, text-only MoE, uncensored)
ADK_MODEL=litellm/openai/gpt-4o

# Synthesis model (optional — defaults to ADK_MODEL)
# Used by the synthesiser agent for uncensored report generation.
# ADK_SYNTHESIS_MODEL=openai/zai-org-glm-4.7
# SYNTHESIS_API_KEY=
# SYNTHESIS_API_BASE=https://api.venice.ai/api/v1

# Thinker model (optional — defaults to ADK_SYNTHESIS_MODEL)
# Used by the thinker agent for uncensored strategic reasoning.
# Set separately to use e.g. abliteration.ai for thinking.
# ADK_THINKER_MODEL=openai/abliteration-model
# THINKER_API_KEY=
# THINKER_API_BASE=https://api.abliteration.ai/v1

# Venice-specific parameters (JSON dict, forwarded as venice_parameters in request body)
# Default: {"include_venice_system_prompt": false} — disables Venice system prompt
# for full prompt control. Only used when OPENAI_API_BASE points to Venice.
# VENICE_PARAMS={"include_venice_system_prompt": false}

# Algorithm tuning
MAX_CONTEXT_TOKENS=128000   # Force final answer above this token estimate
CONTEXT_COMPRESS_LIMIT=5    # Algorithm 6: max retry attempts

# ADK Plugin configuration
CONTEXT_INVOCATIONS_TO_KEEP=2  # ContextFilterPlugin: invocations to retain (replaces KEEP_TOOL_RESULT)
TOOL_MAX_RETRIES=2             # ReflectAndRetryToolPlugin: max retry attempts per tool failure

# Batch orchestration (python main.py --mode batch "query")
# BATCH_WORKERS=3           # Parallel batch workers (asyncio.gather)
# BATCH_SIZE=5              # Items per batch
# FINDINGS_DIR=/tmp/mirothinker  # JSONL findings storage directory


# Observability (AgentOps — auto-instruments ADK with zero custom code)
AGENTOPS_API_KEY=           # Get key at https://app.agentops.ai — leave blank to disable

# OTel observability backends (SQLite always on; Phoenix opt-in)
PHOENIX_ENABLED=            # Set to "1" to stream spans to Phoenix at localhost:6006
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces  # Override Phoenix OTLP endpoint
ADK_DEBUG=                  # Set to "1" for DebugLoggingPlugin (full YAML traces)
ADK_CAPTURE_MESSAGE_CONTENT_IN_SPANS=  # Set to "1" to capture prompts/responses in OTel spans

# Optional
DEMO_MODE=                  # Set to "1" to truncate scrape results to 20K chars
