# Venice AI (OpenAI-compatible, uncensored)
VENICE_API_KEY=
VENICE_API_BASE=https://api.venice.ai/api/v1
VENICE_MODEL=olafangensan-glm-4.7-flash-heretic

# Tool API keys
BRAVE_API_KEY=
FIRECRAWL_API_KEY=
EXA_API_KEY=
KAGI_API_KEY=

# Adaptive loop prevention (multi-agent mode)
# Instead of hard budget exceptions, the researcher's temperature is
# escalated when the planner sends repeated/similar queries, forcing
# the model to explore different search strategies.
BASE_TEMPERATURE=0.7
TEMP_ESCALATION_STEP=0.2
MAX_TEMPERATURE=1.5
SIMILARITY_THRESHOLD=0.6
MAX_SIMILAR_CALLS=3

# Observability (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=
