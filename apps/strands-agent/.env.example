# === TIER 1: Uncensored (primary — use these first) ===
# DuckDuckGo: no key needed (free)
# Stract: no key needed (free, independent open-source search engine)
BRAVE_API_KEY=           # Brave Search — independent index
EXA_API_KEY=             # Exa — neural/semantic search
MOJEEK_API_KEY=          # Mojeek — independent crawler
YANDEX_SEARCH_API_KEY=   # Yandex Search — dominant in Eastern Europe
YANDEX_FOLDER_ID=        # Yandex Cloud folder ID (required with API key)
# Reddit MCP: no key needed (free, forum search/browse/scrape)

# === TIER 2: Content Extraction & OSINT ===
FIRECRAWL_API_KEY=       # Firecrawl — JS rendering, anti-bot
JINA_API_KEY=            # Jina Reader — URL→markdown
KAGI_API_KEY=            # Kagi — search, summarize, small-web enrich
# Wayback Machine: no key needed (free, cached/archived pages)
# Archive.today: no key needed (free, alternative archive source)
SIMILARSITES_API_KEY=    # SimilarSites via RapidAPI — find related domains (free tier: 5000/day)

# === TIER 3: Censored but powerful (fallback) ===
SERPER_API_KEY=          # Google via Serper
TAVILY_API_KEY=          # Tavily — agent-optimized search
PERPLEXITY_API_KEY=      # Perplexity — deep synthesized research

# === Deep Research (high latency, high quality) ===
XAI_API_KEY=             # Grok / xAI — web + X/Twitter deep search
# GROK_RESPONSES_API_BASE=https://api.x.ai  # (default)
# GROK_SEARCH_MODEL=grok-4                   # (default)

# === Academic & Reference (MCP servers + direct APIs) ===
SEMANTIC_SCHOLAR_API_KEY=  # Semantic Scholar — optional, higher rate limits (free to request)
CORE_API_KEY=              # CORE — 300M+ metadata, 40M+ full-text OA papers (free, register at core.ac.uk)
SPRINGER_API_KEY=          # Springer Nature — 7M+ docs, 280K+ open access (free, register at dev.springernature.com)
ZENODO_ACCESS_TOKEN=       # Zenodo — CERN open data repo (free, generate at zenodo.org/account/settings/applications/)
UNPAYWALL_EMAIL=           # Unpaywall — legal OA PDF finder (free, just needs email, no key!)
# arXiv: no key needed (free)
# Wikipedia: no key needed (free)
# CrossRef: no key needed (free, include email for polite pool — 50 req/sec vs 1 req/sec)
# HathiTrust: no key needed (free, 17M+ digitized books)
# Internet Archive: no key needed for public items (free)

# === Book Metadata Enrichment ===
GOOGLE_BOOKS_API_KEY=      # Google Books — ISBN/title → rich metadata (free, optional — works without key)
ISBNDB_API_KEY=            # ISBNdb — 108M+ book titles, 19 data points ($9.95/mo, optional)

# === Internet Archive (for restricted items only) ===
IA_ACCESS_KEY=             # Internet Archive S3-like API (register at archive.org/account/s3.php)
IA_SECRET_KEY=             # Internet Archive S3-like API secret

# === Data & Media (MCP servers) ===
TRANSCRIPTAPI_KEY=       # TranscriptAPI — YouTube transcripts
BRIGHT_DATA_API_KEY=     # Bright Data — anti-block scraping + residential proxy
BRIGHTDATA_CUSTOMER_ID=  # Bright Data customer ID (default: hl_dc044bf4)
BRIGHTDATA_ZONE=         # Bright Data zone (default: mcp_unlocker)
# DuckDB: no key needed (local)

# === Proxy Services ===
OXYLABS_USERNAME=        # Oxylabs — residential proxy fallback
OXYLABS_PASSWORD=        # Oxylabs — residential proxy password

# === Document Extraction (enhanced backends) ===
MATHPIX_APP_ID=          # Mathpix — STEM PDF OCR + LaTeX ($19.99 setup + $0.005/page, optional)
MATHPIX_APP_KEY=         # Mathpix — application key
# DOCLING_ENDPOINT=      # Docling — remote endpoint (optional, defaults to local)
# EXTRACTION_BACKEND=auto  # Force extraction backend: "auto", "docling", "mathpix", "pdfplumber"

# === MCP Servers (paper-search-mcp) ===
# paper-search-mcp wraps arXiv, PubMed, Semantic Scholar, CORE, Unpaywall, Zenodo, IEEE, ACM
# Install: pip install paper-search-mcp
# PAPER_SEARCH_MCP_UNPAYWALL_EMAIL=        # (same as UNPAYWALL_EMAIL)
# PAPER_SEARCH_MCP_CORE_API_KEY=           # (same as CORE_API_KEY)
# PAPER_SEARCH_MCP_SEMANTIC_SCHOLAR_API_KEY=  # (same as SEMANTIC_SCHOLAR_API_KEY)
# PAPER_SEARCH_MCP_ZENODO_ACCESS_TOKEN=    # (same as ZENODO_ACCESS_TOKEN)
# PAPER_SEARCH_MCP_IEEE_API_KEY=           # IEEE Xplore — register at developer.ieee.org

# === Model ===
VENICE_API_KEY=
VENICE_API_BASE=https://api.venice.ai/api/v1
VENICE_MODEL=olafangensan-glm-4.7-flash-heretic

# === YouTube Intelligence ===
YOUTUBE_API_KEY=             # YouTube Data API v3 — faster comment extraction
# yt-dlp: no key needed (installed via pip, handles video/audio/subtitle download)
# whisper: optional (pip install openai-whisper) — audio transcription fallback

# === B2 Datalake (persistent artifact storage) ===
B2_KEY_ID=                   # Backblaze B2 application key ID
B2_APPLICATION_KEY=          # Backblaze B2 application key
# B2_DATALAKE_BUCKET=mirothinker-datalake  # (default) — bucket name

# === Research Persistence & Cache ===
# FINDINGS_DIR=~/.mirothinker      # (default) — findings + knowledge graph
# MIROTHINKER_CACHE_DIR=~/.mirothinker/cache  # (default) — persistent content cache
# CACHE_DEFAULT_TTL=604800         # (default 7 days) — cache entry time-to-live in seconds

# === Preprint Servers (bypass journal gatekeeping) ===
# bioRxiv / medRxiv: no key needed (free, Cold Spring Harbor Lab)
# ChemRxiv: no key needed (free, American Chemical Society)
# SSRN: no key needed (free, Elsevier — 1M+ social science preprints)
# OSF Preprints: no key needed (free, one API for 30+ preprint communities)

# === Research Integrity ===
# Open Retractions: no key needed (free, instant DOI → retraction check)
# Retraction Watch: no key needed (free via CrossRef, 40K+ retracted papers)

# === Government & Legal Intelligence ===
# ClinicalTrials.gov: no key needed (free, v2 API — suppressed drug trials)
# OpenFDA: no key needed (free — FAERS adverse events, drug recalls)
OPENFDA_API_KEY=             # OpenFDA — optional, higher rate limits (free at open.fda.gov)
COURTLISTENER_API_TOKEN=     # CourtListener — free PACER access (register at courtlistener.com)
# SEC EDGAR: no key needed (free — corporate filings, insider trading)
# ICIJ Offshore Leaks: no key needed (free CSV — Panama/Paradise/Pandora Papers)

# === Deep Academic Knowledge ===
# OpenAlex: no key needed (free, 240M+ works, replaces Microsoft Academic Graph)
# PubMed / NCBI: no key needed (free, 36M+ biomedical citations)
NCBI_API_KEY=                # NCBI — optional, 10 req/sec vs 3 (free at ncbi.nlm.nih.gov/account/)
# Wikidata: no key needed (free, 100M+ structured entities, SPARQL)
SERPAPI_KEY=                 # SerpAPI — for Google Scholar (paid, serpapi.com)

# === OSINT & Dark Web ===
SHODAN_API_KEY=              # Shodan — internet device search (for osint-mcp)
VIRUSTOTAL_API_KEY=          # VirusTotal — malware/URL analysis (for osint-mcp)
CENSYS_API_ID=               # Censys — internet-wide scanning (for osint-mcp)
CENSYS_API_SECRET=           # Censys API secret
SECURITYTRAILS_API_KEY=      # SecurityTrails — DNS/domain history (for osint-mcp)
TELEGRAM_API_ID=             # Telegram — for OSINT Intelligence Platform
TELEGRAM_API_HASH=           # Telegram API hash
# OnionClaw: no key needed (free, requires Tor — apt install tor)
# Onion Search: no key needed (free, anonymous Tor browsing)
# OSINT Tools (Sherlock/SpiderFoot): no key needed (free)

# === Censorship-Resistant Infrastructure ===
# IPFS: no key needed (free, decentralized content — DMCA-removed papers persist)
# Wayback Machine CDX: no key needed (free, recover censored web content)
# Common Crawl: no key needed (free, 300B+ archived web pages)
# IACR ePrint: no key needed (free, cryptography/privacy research)
# Beacon Censorship DB: no key needed (Norwegian National Library)

# === LibGen / Shadow Libraries (mirror domains) ===
# LIBGEN_MIRROR=https://libgen.li    # (default)
# ANNAS_DOMAIN=https://annas-archive.se  # (default)
# SCIHUB_DOMAIN=https://sci-hub.se   # (default)
# ZLIB_DOMAIN=https://z-lib.gs       # (default — Z-Library, FBI-seized, rotating mirrors)

# === Budget & Limits ===
# MAX_TOOL_CALLS=200       # max tool invocations per request
# SESSION_TIMEOUT=3600     # session timeout in seconds

# === MCP Server Startup ===
# MCP_STARTUP_TIMEOUT=120  # seconds to wait for MCP server init

# === Observability (optional) ===
OTEL_EXPORTER_OTLP_ENDPOINT=
