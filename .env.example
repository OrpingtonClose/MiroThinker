# =============================================================================
# MiroThinker — Complete Environment Variable Reference
# =============================================================================
# Copy to .env and fill in the values you need.
# Components: proxies, strands-agent, MCP servers, services, infrastructure
# =============================================================================

# === LLM API Keys (model providers) ===
# Priority cascade: VENICE_API_KEY > XAI_API_KEY > MISTRAL_API_KEY
VENICE_API_KEY=              # Venice AI — uncensored models (primary)
XAI_API_KEY=                 # xAI/Grok — deep research, X/Twitter search
MISTRAL_API_KEY=             # Mistral — thinking proxy fallback
OPENROUTER_API_KEY=          # OpenRouter — multi-model routing

# Derived variables (set automatically by startup.sh based on which keys are present):
# UPSTREAM_KEY, UPSTREAM_BASE, UPSTREAM_MODEL, SUBAGENT_MODEL

# === Search & Content Extraction ===
BRAVE_API_KEY=               # Brave Search — independent index
EXA_API_KEY=                 # Exa — neural/semantic search
FIRECRAWL_API_KEY=           # Firecrawl — JS rendering, anti-bot
MOJEEK_API_KEY=              # Mojeek — independent crawler
JINA_API_KEY=                # Jina Reader — URL to markdown
KAGI_API_KEY=                # Kagi — search, summarize, small-web enrich
SERPER_API_KEY=              # Google via Serper
TAVILY_API_KEY=              # Tavily — agent-optimized search
PERPLEXITY_API_KEY=          # Perplexity — deep synthesized research
YANDEX_SEARCH_API_KEY=       # Yandex Search — dominant in Eastern Europe
YANDEX_FOLDER_ID=            # Yandex Cloud folder ID

# === Data Sources & Scraping ===
BRIGHT_DATA_API_KEY=         # Bright Data — anti-block scraping + residential proxy
BRIGHT_DATA_PROXY_URL=       # Bright Data — residential proxy URL for YouTube/web
BRIGHTDATA_CUSTOMER_ID=      # Bright Data customer ID (default: hl_dc044bf4)
BRIGHTDATA_ZONE=             # Bright Data zone (default: mcp_unlocker)
APIFY_API_TOKEN=             # Apify actors (Reddit, Instagram, TikTok, LinkedIn)
TRANSCRIPTAPI_KEY=           # TranscriptAPI — YouTube transcripts
OXYLABS_USERNAME=            # Oxylabs — residential proxy fallback
OXYLABS_PASSWORD=            # Oxylabs — residential proxy password

# === Academic & Reference ===
SEMANTIC_SCHOLAR_API_KEY=    # Semantic Scholar — optional, higher rate limits
CORE_API_KEY=                # CORE — 300M+ metadata, 40M+ full-text OA papers
SPRINGER_API_KEY=            # Springer Nature — 7M+ docs
ZENODO_ACCESS_TOKEN=         # Zenodo — CERN open data repo
UNPAYWALL_EMAIL=             # Unpaywall — legal OA PDF finder (just needs email)
NCBI_API_KEY=                # NCBI/PubMed — optional, 10 req/sec vs 3
SERPAPI_KEY=                 # SerpAPI — for Google Scholar
GOOGLE_BOOKS_API_KEY=        # Google Books — ISBN/title to metadata
ISBNDB_API_KEY=              # ISBNdb — 108M+ book titles

# === YouTube Intelligence ===
YOUTUBE_API_KEY=             # YouTube Data API v3

# === Government & Legal ===
OPENFDA_API_KEY=             # OpenFDA — optional, higher rate limits
COURTLISTENER_API_TOKEN=     # CourtListener — free PACER access

# === OSINT ===
SHODAN_API_KEY=              # Shodan — internet device search
VIRUSTOTAL_API_KEY=          # VirusTotal — malware/URL analysis
CENSYS_API_ID=               # Censys — internet-wide scanning
CENSYS_API_SECRET=           # Censys API secret
SECURITYTRAILS_API_KEY=      # SecurityTrails — DNS/domain history
TELEGRAM_API_ID=             # Telegram OSINT
TELEGRAM_API_HASH=           # Telegram API hash

# === Document Extraction ===
MATHPIX_APP_ID=              # Mathpix — STEM PDF OCR + LaTeX
MATHPIX_APP_KEY=             # Mathpix application key

# === Internet Archive ===
IA_ACCESS_KEY=               # Internet Archive S3-like API
IA_SECRET_KEY=               # Internet Archive S3-like API secret

# === B2 Storage (model downloads + datalake) ===
B2_APPLICATION_KEY_ID=       # Backblaze B2 key ID
B2_APPLICATION_KEY=          # Backblaze B2 application key
# B2_DATALAKE_BUCKET=mirothinker-datalake  # (default)

# === Infrastructure ===
CLOUDFLARE_TUNNEL_TOKEN=     # Cloudflare tunnel for public access
SEARCH_BACKEND=legacy        # "legacy" or "mcp" (MCP enables search dispatcher)
OLLAMA_BASE_URL=http://localhost:11434  # Local Ollama endpoint for local models

# === Swarm Local Models (localhost-only — guard rejects remote APIs) ===
# SWARM_API_BASE=http://localhost:11434/v1  # Derived from OLLAMA_BASE_URL/v1
# SWARM_WORKER_MODEL=gemma-4-uncensored     # Workers: fast uncensored
# SWARM_QUEEN_MODEL=qwen-claude-opus        # Queen merge: best writer
# SWARM_SERENDIPITY_MODEL=qwen-claude-opus  # Serendipity: cross-domain reasoner

# === Neo4j (Knowledge Graph) ===
NEO4J_PASSWORD=neo4j_deep_search  # Neo4j password (default for unattended)
# NEO4J_BOLT_PORT=7687
# NEO4J_HTTP_PORT=7474

# === LibreChat ===
# JWT_SECRET=                # LibreChat JWT secret
# GOOGLE_CLIENT_ID=          # OAuth (optional)
# GOOGLE_CLIENT_SECRET=      # OAuth (optional)

# === Langfuse (Observability) ===
# LANGFUSE_SECRET_KEY=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_URL=http://localhost:3001
OTEL_EXPORTER_OTLP_ENDPOINT= # OpenTelemetry collector

# === Port Overrides (defaults shown) ===
# THINKING_PROXY_PORT=9100
# DEEP_RESEARCH_PORT=9200
# PERSISTENT_RESEARCH_PORT=9300
# MIROFLOW_SPRINT_PORT=9400
# SWARM_PROXY_PORT=9500
# GODMODE_PROXY_PORT=9600
# XAI_PROXY_PORT=9700
# PERSISTENT_WIKI_PORT=9800
# MIROFLOW_SPRINT_WIKI_PORT=9850
# TIER_CHOOSER_PORT=9900
# HERETIC_PROXY_PORT=9950
# MIRO_PROXY_PORT=9951
# STRANDS_AGENT_PORT=8100
# KE_PORT=9850
# MCP_DISPATCHER_PORT=9801
# LITELLM_PORT=4000

# === Budget & Limits ===
# MAX_TOOL_CALLS=200
# SESSION_TIMEOUT=3600
# MONTHLY_BUDGET=100
# SESSION_BUDGET=10

# === Research Persistence ===
# FINDINGS_DIR=~/.mirothinker
# MIROTHINKER_CACHE_DIR=~/.mirothinker/cache
# CACHE_DEFAULT_TTL=604800

# === Shadow Libraries (mirror domains) ===
# LIBGEN_MIRROR=https://libgen.li
# ANNAS_DOMAIN=https://annas-archive.se
# SCIHUB_DOMAIN=https://sci-hub.se
# ZLIB_DOMAIN=https://z-lib.gs

# === Vast.ai (GPU provisioning) ===
# VAST_API_KEY=
