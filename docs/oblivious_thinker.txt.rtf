def admit_thought(  \
    self,  \
    reasoning: str,  \
    parent_thought_id: int | None = None,  \
    related_finding_ids: list[int] | None = None,  \
    angle: str = "",  \
    strategy: str = "",  \
    iteration: int = 0,  \
    expansion_depth: int = 0,  \
) -> int:  \
    """Insert a thought row into the conditions table.  \
      \
    The full reasoning text goes into `fact` with NO truncation.  \
    parent_id links to the previous thought in the chain (lineage).  \
    related_id can link to a finding this thought was responding to.  \
    """  \
    cid = self._next_id  \
    self._next_id += 1  \
    now = datetime.now(timezone.utc).isoformat()  \
    self.conn.execute(  \
        """INSERT INTO conditions  \
           (id, fact, row_type, parent_id, related_id,  \
            consider_for_use, angle, strategy,  \
            expansion_depth, created_at, iteration)  \
           VALUES (?, ?, 'thought', ?, ?, TRUE, ?, ?, ?, ?, ?)""",  \
        [  \
            cid, reasoning,  # FULL text, no truncation  \
            parent_thought_id,  \
            related_finding_ids[0] if related_finding_ids else None,  \
            angle, strategy, expansion_depth, now, iteration,  \
        ],  \
    )  \
    return cid\
