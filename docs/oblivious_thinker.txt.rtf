@dataclass  \
class ReasoningSnapshot:  \
    version: int                  # monotonically increasing  \
    chunk_ids: list[int]          # which corpus finding IDs were in this chunk  \
    inherited_reasoning: str      # reasoning from version N-1 (or "" for v0)  \
