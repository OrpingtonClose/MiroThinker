\
def get_thought_lineage(self, thought_id: int | None = None) -> list[dict]:  \
    """Get the full chain of thought from a given thought back to root.  \
    If thought_id is None, starts from the latest thought."""  \
    if thought_id is None:  \
        row = self.conn.execute(  \
            "SELECT id FROM conditions WHERE row_type = 'thought' ORDER BY id DESC LIMIT 1"  \
        ).fetchone()  \
        if not row:  \
            return []  \
        thought_id = row[0]  \
      \
    rows = self.conn.execute("""  \
        WITH RECURSIVE lineage AS (  \
            SELECT * FROM conditions WHERE id = ? AND row_type = 'thought'  \
            UNION ALL  \
            SELECT c.* FROM conditions c   \
            JOIN lineage l ON c.id = l.parent_id  \
            WHERE c.row_type = 'thought'  \
        )  \
        SELECT * FROM lineage ORDER BY id ASC  \
    """, [thought_id]).fetchall()  \
    # Convert to dicts using column names  \
    cols = [desc[0] for desc in self.conn.description]  \
    return [dict(zip(cols, row)) for row in rows]\
