# =============================================================================
# H200 Swarm Test — Environment Variables
# =============================================================================
# Copy to .env and source before running: source .env
# =============================================================================

# ── vLLM Server ──────────────────────────────────────────────────────
# Which model to serve. Pick ONE per test run.
# Test 1 (32B FP16): Qwen3.5-32B — 64GB weights, 77GB KV cache
export VLLM_MODEL="huihui-ai/Qwen3.5-32B-abliterated"
export VLLM_DTYPE="auto"

# Test 2 (70B FP8): Llama-3.3-70B — 70GB weights, 71GB KV cache
# export VLLM_MODEL="huihui-ai/Llama-3.3-70B-Instruct-abliterated"
# export VLLM_DTYPE="float8"

export VLLM_PORT=8000
export VLLM_MAX_MODEL_LEN=32768
export VLLM_GPU_UTIL=0.92

# ── Swarm Configuration ──────────────────────────────────────────────
export SWARM_API_BASE="http://localhost:8000/v1"
export SWARM_WORKER_MODEL="${VLLM_MODEL}"
export SWARM_QUEEN_MODEL="${VLLM_MODEL}"
export SWARM_SERENDIPITY_MODEL="${VLLM_MODEL}"
export SWARM_MAX_WORKERS=8
export SWARM_GOSSIP_ROUNDS=3
export SWARM_MIN_GOSSIP_ROUNDS=2
export SWARM_WORKER_MAX_TOKENS=16384
export SWARM_QUEEN_MAX_TOKENS=32768

# Thread-discovery mechanisms (all enabled)
export SWARM_SERENDIPITY=1
export SWARM_FULL_CORPUS_GOSSIP=1
export SWARM_SEMANTIC_ASSIGNMENT=1
export SWARM_MISASSIGNMENT=1
export SWARM_MISASSIGNMENT_RATIO=0.25
export SWARM_HIVE_MEMORY=1
export SWARM_DAR_GOSSIP=1

# ── Search API Keys (optional — DDG/forums work without any) ────────
# export BRAVE_API_KEY=
# export JINA_API_KEY=
# export NCBI_API_KEY=
